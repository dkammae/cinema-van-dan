ategory":"Beste film (drama)","categoryKey":"best picture drama","entityType":"film","name":"One Battle After Another (2025)"}],"awardSummary":{"wins":11,"nominations":7}},{"id":"f6sw-mgRG-U8","title":"Milk","year":"2008","stars":5,"genres":["Drama","Biografie","Gay interest"],"description":"Biografisch drama over Harvey Milk's politieke strijd.","synopsis":"\"Milk\" (2008) is een biografisch drama dat het leven volgt van Harvey Milk, de eerste openlijk homoseksuele man die in Californië werd verkozen voor een openbaar ambt. De film toont zijn transformatie van een activist in de wijk Castro in San Francisco tot een invloedrijk politicus die strijdt voor gelijke rechten en tegen discriminatie. Terwijl hij politieke successen boekt, waaronder zijn verkiezing in de Board of Supervisors, loopt de spanning op met zijn conservatieve collega Dan White, wat uiteindelijk leidt tot de tragische moord op Milk en burgemeester George Moscone in 1978.","directors":["Gus Van Sant"],"awards":[],"awardSummary":{"wins":0,"nominations":0}}],"awards":[{"ceremony":"The Oscars","year":"2026","status":"win","category":"Acteur bijrol","categoryKey":"supporting actor","entityType":"cast","name":"Sean Penn"},{"ceremony":"The Bafta's","year":"2026","status":"win","category":"Acteur bijrol","categoryKey":"supporting actor","entityType":"cast","name":"Sean Penn"},{"ceremony":"SAG","year":"2026","status":"win","category":"Acteur bijrol","categoryKey":"supporting actor","entityType":"cast","name":"Sean Penn"},{"ceremony":"Critics choice","year":"2026","status":"nomination","category":"Acteur bijrol","categoryKey":"supporting actor","entityType":"cast","name":"Sean Penn"}],"awardSummary":{"wins":3,"nominations":1}}